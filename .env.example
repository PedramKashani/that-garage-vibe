# Sender hosted embed integration (maintenance-free)
# Paste the script URL from Sender's embed snippet.
VITE_SENDER_EMBED_SCRIPT_URL="https://cdn.sender.net/accounts_resources/universal.js"

# Paste your Sender account/embed ID from the snippet sender('...').
VITE_SENDER_ACCOUNT_ID="your_sender_account_id"

# Optional: if Sender provides a specific embedded form ID, include it.
VITE_SENDER_FORM_ID="your_sender_form_id"
